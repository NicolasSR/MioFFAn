        "concepts_list": [
            {
                "name": "rho",
                "type": "VARIABLE",
                "description": "fluid density",
                "justification": "appears as \u03c1 in momentum equation (1) and continuity. Explicitly defined as variable in \u00a71."
            },
            {
                "name": "u",
                "type": "VARIABLE",
                "description": "fluid velocity field",
                "justification": "defined throughout as vector field u(x,t) with components referenced in the system."
            },
            {
                "name": "p",
                "type": "VARIABLE",
                "description": "pressure field",
                "justification": "present as scalar p in momentum equation (1)."
            },
            {
                "name": "mu",
                "type": "VARIABLE",
                "description": "dynamic viscosity",
                "justification": "\u03bc is the fluid dynamic viscosity, described in the non\u2011Newtonian model."
            },
            {
                "name": "gamma",
                "type": "VARIABLE",
                "description": "shear\u2011rate",
                "justification": "\u03b3\u02d9 is the shear\u2011rate appearing in the Carreau model for viscosity."
            },
            {
                "name": "zeta",
                "type": "VARIABLE",
                "description": "auxiliary parameter (0 \u2264 \u03b6 \u2264 1)",
                "justification": "\u03b6 appears in the viscosity model, limited to [0,1] as a design parameter."
            },
            {
                "name": "S",
                "type": "VARIABLE",
                "description": "viscous stress tensor",
                "justification": "S = 2\u03bc\u2207s**u, as given in Eq.(3)."
            },
            {
                "name": "Omega",
                "type": "DOMAIN",
                "description": "fluid domain",
                "justification": "\u03a9 is the bounded region of integration where the equations hold."
            },
            {
                "name": "Gamma",
                "type": "VARIABLE",
                "description": "unit normal vector on boundary",
                "justification": "\u0393 is the outward unit normal defined as \u2202\u03a9, used in traction conditions."
            },
            {
                "name": "Nelements",
                "type": "VARIABLE",
                "description": "number of elements in the mesh",
                "justification": "N is defined as count of elements (e) in the mesh."
            },
            {
                "name": "h",
                "type": "VARIABLE",
                "description": "element size",
                "justification": "h = max_e h_e, controls element size and stability."
            },
            {
                "name": "delta",
                "type": "VARIABLE",
                "description": "mesh\u2011size dependent scalar parameter",
                "justification": "\u03b4_e is the per\u2011element distance parameter used in stabilisation."
            },
            {
                "name": "X",
                "type": "DOMAIN",
                "description": "unit tangent plane of boundary X",
                "justification": "X is a continuous finite element space, a domain of (u,t) functions."
            }
        ],
