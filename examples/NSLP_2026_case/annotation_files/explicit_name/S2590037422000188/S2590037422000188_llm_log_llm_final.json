        "concepts_list": [
            {
                "name": "displacement_vector",
                "type": "VARIABLE",
                "description": "Displacement vector of the lumbar spine, represented as components u_i in the spatial directions.",
                "justification": "where u_i are the components of the spine displacement. The notation u_k,l and u_l,k appears in strain\u2013displacement relations, indicating spatial derivatives of displacement components."
            },
            {
                "name": "stress_tensor",
                "type": "VARIABLE",
                "description": "Stress tensor components \u03c3_ij representing internal forces per unit area in the spine material.",
                "justification": "\u03c3_ij are the components of the stress tensor, defined in the stress equilibrium equation and related to strain via Hooke\u2019s law."
            },
            {
                "name": "strain_tensor",
                "type": "VARIABLE",
                "description": "Strain tensor components \u03b5_kl representing deformation of the spine material.",
                "justification": "\u03b5_kl are the components of the strain tensor, derived from the displacement components via strain\u2013displacement relation."
            },
            {
                "name": "stiffness_tensor",
                "type": "VARIABLE",
                "description": "Stiffness tensor components C_i_j_k_l describing the material's resistance to deformation in the spine.",
                "justification": "C_i_j_k_l are the components of the stiffness tensor of the spine, used in the generalized Hooke\u2019s law to relate stress and strain."
            },
            {
                "name": "body_force_vector",
                "type": "VARIABLE",
                "description": "Body force components f_i representing external forces per unit mass acting on the spine material.",
                "justification": "f_i are the components of the body force, appearing in the stress equilibrium equation and integrated over the domain."
            },
            {
                "name": "weight_function",
                "type": "VARIABLE",
                "description": "Test function v_i used in the variational formulation to enforce equilibrium in the finite element method.",
                "justification": "Taking the weight function v_i, we obtain the variational statement. The function v_i appears in integrals with stress and body forces."
            },
            {
                "name": "surface_force_vector",
                "type": "VARIABLE",
                "description": "Surface force components F_i applied on the boundary of the domain, derived from the stress tensor and normal vector.",
                "justification": "F_i is the body force applied on the boundary \u2202\u03a9, expressed as \u03c3_ij n_j, linking surface forces to the stress tensor and normal vector."
            },
            {
                "name": "domain",
                "type": "DOMAIN",
                "description": "The main computational domain \u03a9 representing the lumbar spine region under analysis.",
                "justification": "\u03a9 appears as the domain of integration in multiple equations, such as \u222b_\u03a9 and \u222b_\u2202\u03a9, indicating the physical region of the spine."
            },
            {
                "name": "boundary",
                "type": "DOMAIN",
                "description": "The boundary \u2202\u03a9 of the domain \u03a9, where surface forces are applied.",
                "justification": "\u2202\u03a9 is the outward boundary of the domain, where surface forces F_i are defined and integrated over."
            },
            {
                "name": "volume_integral_var",
                "type": "INTEGRATION_VAR",
                "description": "Integration variable d\u03a9 used in volume integrals over the domain \u03a9.",
                "justification": "d\u03a9 appears in integrals over \u03a9, such as \u222b_\u03a9 \u03c3_ij v_i,j d\u03a9, indicating the volume integration element."
            },
            {
                "name": "surface_integral_var",
                "type": "INTEGRATION_VAR",
                "description": "Integration variable d\u03a9 used in surface integrals over the boundary \u2202\u03a9.",
                "justification": "d\u03a9 appears in integrals over \u2202\u03a9, such as \u222b_\u2202\u03a9 F_i v_i d\u03a9, indicating the surface integration element."
            },
            {
                "name": "gradient_operator",
                "type": "OPERATOR",
                "description": "Divergence operator \u2207\u22c5 used in the weak form to transform stress and displacement gradients.",
                "justification": "The divergence property is applied to convert the stress equilibrium equation into a variational form involving \u2207\u22c5\u03c3 and \u2207v."
            }
        ],
