            },
            "concept_category": "variable"
        },
        "test_function_v": {
            "code_var_name": "test_function_v",
            "description": "A test function used in the weak formulation, belonging to the function space V, and is varied over the domain to satisfy the weak form.\nJUSTIFICATION:\nThe symbol v appears in multiple integrals and is used in the weak form as a test function for all v \u2208 V. It is central to the variational formulation and is used in both the left-hand and right-hand sides of the equations.",
            "primitive_symbols": [
                "76"
            ],
            "sog_list": [],
            "properties": {
                "type": "test-function",
                "tensor-rank": "0"
            },
            "concept_category": "variable"
        },
        "test_space_V": {
            "code_var_name": "test_space_V",
            "description": "The function space of test functions, which is used in the weak formulation and must contain functions that satisfy the necessary boundary conditions.\nJUSTIFICATION:\nThe symbol V is defined as the space of test functions, and the weak form is stated to hold for all v \u2208 V. It is used in the formulation and discretization process.",
            "primitive_symbols": [
                "56"
