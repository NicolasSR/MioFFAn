        "concepts_list": [
            {
                "name": "stress_tensor_ij",
                "type": "VARIABLE",
                "description": "Components of the stress tensor in the i-j direction.",
                "justification": "Explicitly defined as \u03c3_ij in equations (1a), (1b), and (1c). Appears in multiple formulations as the primary mechanical quantity related to internal forces."
            },
            {
                "name": "body_force_i",
                "type": "VARIABLE",
                "description": "Components of the body force acting in the i direction.",
                "justification": "Defined as f_i in equations (1a), (1b), and (1c), and appears in the weak form as a source term in the variational equation (3)."
            },
            {
                "name": "stiffness_tensor_ijkl",
                "type": "VARIABLE",
                "description": "Components of the stiffness tensor relating stress and strain in the i-j-k-l direction.",
                "justification": "Defined as C_ijkl in equation (1b) and used in equation (9) to relate stress to strain via Hooke's law."
            },
            {
                "name": "strain_tensor_kl",
                "type": "VARIABLE",
                "description": "Components of the strain tensor in the k-l direction, derived from displacement gradients.",
                "justification": "Defined as \u03b5_kl in equation (1c) and used in equation (9) as a function of displacement gradients (u_k,l and u_l,k)."
            },
            {
                "name": "displacement_u",
                "type": "VARIABLE",
                "description": "Components of the displacement field in the i direction.",
                "justification": "Defined as u_i in equation (1c) and appears in the strain tensor definition and final weak form (10)."
            },
            {
                "name": "weight_function_v_i",
                "type": "VARIABLE",
                "description": "Weight function used in the variational formulation, with components v_i.",
                "justification": "Introduced in equation (3) as the test function v_i, used in integration to derive the weak form of the equilibrium equation."
            },
            {
                "name": "boundary_force_F_i",
                "type": "VARIABLE",
                "description": "Components of the surface force applied on the boundary, expressed as the dot product of stress and normal vector.",
                "justification": "Defined in equation (7) as F_i = \u03c3_ij n_j, and appears in the weak form as a boundary term in equation (8) and (10)."
            },
            {
                "name": "domain_Omega",
                "type": "DOMAIN",
                "description": "The computational domain representing the lumbar spine region under analysis.",
                "justification": "Appears in integrals over \u03a9 (e.g., \u222b_\u03a9 and \u222b_\u2202\u03a9), and is referenced as the region where the physical model is defined."
            },
            {
                "name": "boundary_partial_Omega",
                "type": "DOMAIN",
                "description": "The boundary of the computational domain, where surface forces are applied.",
                "justification": "Appears in the surface integral \u222b_\u2202\u03a9, and is explicitly described as the boundary of the domain \u03a9 where body forces and surface forces are applied."
            },
            {
                "name": "d_Omega",
                "type": "INTEGRATION_VAR",
                "description": "Differential element of volume used in volume integrals over the domain.",
                "justification": "Appears in integrals over \u03a9 as 'd\u03a9' in equations (3), (5), (6), (8), (10), and is standard notation for volume integration in FEM."
            },
            {
                "name": "partial_Omega",
                "type": "INTEGRATION_VAR",
                "description": "Differential element of surface area used in surface integrals over the boundary.",
                "justification": "Appears in \u222b_\u2202\u03a9 as 'd\u2202\u03a9' or '\u2202\u03a9', and is used to represent surface integration over the boundary of the domain."
            },
            {
                "name": "strain_gradient_u_k_l",
                "type": "VARIABLE",
                "description": "First-order derivative of displacement in the k-l direction, used in strain definition.",
                "justification": "Defined as u_k,l and u_l,k in equation (1c), forming the symmetric strain tensor components."
            }
        ],
