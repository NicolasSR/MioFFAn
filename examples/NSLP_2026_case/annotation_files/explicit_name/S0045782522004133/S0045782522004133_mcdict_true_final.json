        "H_0_1_space": {
            "code_var_name": "H_0_1_space",
            "description": "The Sobolev space of functions with zero trace on the boundary, used for the test functions and solution in the weak form.\nJUSTIFICATION:\nThe symbol H\u2080\u00b9(\u03a9) is repeatedly used to describe the space of test functions and the solution space, indicating it is a function space domain.",
            "primitive_symbols": [
                "48"
            ],
            "sog_list": [
                {
                    "start_id": "p_16_2-9",
                    "stop_id": "p_16_5-start",
                    "type": 0
                },
                {
                    "start_id": "p_16_6-2",
                    "stop_id": "p_16_7-start",
                    "type": 0
                }
            ],
            "properties": {},
            "concept_category": "domain"
        },
        "H_1_space": {
            "code_var_name": "H_1_space",
            "description": "The space of functions in H\u00b9(\u03a9) with smoothness in time, used to define the solution space in the weak formulation.\nJUSTIFICATION:\nThe symbol H\u00b9(\u03a9) is used to define the solution space over time, specifically in the formulation 'Find u \u2208 H\u00b9(T; H\u2080\u00b9(\u03a9))', indicating it is a function space domain.",
            "primitive_symbols": [
                "48"
            ],
            "sog_list": [
                {
                    "start_id": "p_18_0-1",
                    "stop_id": "p_18_4-start",
                    "type": 0
                }
            ],
            "properties": {},
            "concept_category": "domain"
        },
        "H_minus1_space": {
            "code_var_name": "H_minus1_space",
            "description": "The dual space of H\u2081\u2080(\u03a9), used for the second time derivative of the solution in the weak formulation.\nJUSTIFICATION:\nThe symbol H\u207b\u00b9(\u03a9) appears in the weak formulation as the dual space of H\u2080\u00b9(\u03a9), associated with the pairing of the second time derivative of u with the test function w.",
            "primitive_symbols": [
                "48"
            ],
            "sog_list": [
                {
                    "start_id": "p_16_2-9",
                    "stop_id": "p_16_6-start",
                    "type": 0
                }
            ],
            "properties": {},
            "concept_category": "domain"
        },
        "Omega_domain": {
            "code_var_name": "Omega_domain",
            "description": "The main spatial domain in which the wave equation is defined and solved.\nJUSTIFICATION:\nThe symbol '\u03a9' is repeatedly used to denote the spatial domain and is the domain of integration in all weak form equations, including integrals over \u03a9 and its subdomains.",
