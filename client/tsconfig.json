  "compilerOptions": {
    "target": "ES2019",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    //Next two are needed to import JSON files as modules, e.g. config.json
    "module": "commonjs",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
