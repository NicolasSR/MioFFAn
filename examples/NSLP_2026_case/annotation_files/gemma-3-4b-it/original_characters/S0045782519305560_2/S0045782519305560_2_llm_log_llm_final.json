        "concepts_list": [
            {
                "name": "sigma_u",
                "type": "VARIABLE",
                "description": "Cauchy stress tensor acting on the displacement field u",
                "justification": "Defined as C*epsilon_v.  The formula states: \u222b(\u2207v\u22c5(\u03ba\u2207u))d\u03a9 = \u222bv*f d\u03a9 + \u222b\u0393_t v*q\u0304 d\u0393."
            },
            {
                "name": "epsilon_v",
                "type": "VARIABLE",
                "description": "Linearized strain tensor evaluated at the function v",
                "justification": "Defined as (1/2)*(\u2207u + \u2207u^T). The formula states: \u222b(\u2207v\u22c5(\u03ba\u2207u))d\u03a9 = \u222bv*f d\u03a9 + \u222b\u0393_t v*q\u0304 d\u0393."
            },
            {
                "name": "Omega_domain",
                "type": "DOMAIN",
                "description": "Main computational domain",
                "justification": "Explicitly stated as \u03a9\u2282R^d. Non-EXPLICIT REASONING: Commonly used notation for the domain of interest."
            },
            {
                "name": "Gamma_boundary",
                "type": "DOMAIN",
                "description": "Boundary of the domain",
                "justification": "Defined as \u0393\u2261\u03a9\u0304\u2216\u03a9, with outward unit normal n. Non-EXPLICIT REASONING: Standard notation for the boundary of a domain."
            },
            {
                "name": "n_normal",
                "type": "OPERATOR",
                "description": "Outward unit normal vector",
                "justification": "Explicitly stated as the outward unit normal. Non-EXPLICIT REASONING: Standard notation for the outward unit normal vector."
            },
            {
                "name": "Gamma_tu",
                "type": "DOMAIN",
                "description": "Interface between subdomain i and j",
                "justification": "Defined as \u0393_{i,j} = \u0393_i \u2229 \u0393_j. Non-EXPLICIT REASONING: Interface between two subdomains."
            },
            {
                "name": "Omega_i",
                "type": "DOMAIN",
                "description": "i-th subdomain",
                "justification": "Each subdomain is denoted as \u03a9_i. Non-EXPLICIT REASONING: A subdomain of the overall domain."
            },
            {
                "name": "v_func",
                "type": "VARIABLE",
                "description": "Test function in the Galerkin method",
                "justification": "Used in the weak formulation (Eq. 3). Non-EXPLICIT REASONING: Function to be integrated."
            },
            {
                "name": "f_source",
                "type": "VARIABLE",
                "description": "Heat source term",
                "justification": "Defined as f in the heat equation. Non-EXPLICIT REASONING: Heat source term."
            },
            {
                "name": "q_bar",
                "type": "VARIABLE",
                "description": "Prescribed heat flux",
                "justification": "Defined as q\u0304 on \u0393_t. Non-EXPLICIT REASONING: Prescribed heat flux."
            },
            {
                "name": "kappa_conductivity",
                "type": "VARIABLE",
                "description": "Thermal conductivity",
                "justification": "Defined as \u03ba. Non-EXPLICIT REASONING: Thermal conductivity parameter."
            },
            {
                "name": "u_solution",
                "type": "VARIABLE",
                "description": "Temperature field",
                "justification": "The unknown solution to the steady-state thermal boundary value problem.  Non-EXPLICIT REASONING: Solution variable."
            }
        ],
