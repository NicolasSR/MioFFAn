        "d_Omega_domain": {
            "code_var_name": "d_Omega_domain",
            "description": "The differential element of the spatial domain \u03a9, used in volume integrals.\nJUSTIFICATION:\nThe symbol 'd\u03a9' appears in integrals over \u03a9, such as in the weak form, and is used to denote the volume element in the integration.",
