        "stress_tensor_sigma_u": {
            "code_var_name": "stress_tensor_sigma_u",
            "description": "The Cauchy stress tensor computed from the strain field via the constitutive relation \u03c3(u) = C\u03b5(u).\nJUSTIFICATION:\nThe expression \u03c3(u) is explicitly defined as the stress tensor, formed from the constitutive tensor C and the strain tensor \u03b5(u), and is used in the elastostatics weak form.",
            "primitive_symbols": [
                "cf83",
