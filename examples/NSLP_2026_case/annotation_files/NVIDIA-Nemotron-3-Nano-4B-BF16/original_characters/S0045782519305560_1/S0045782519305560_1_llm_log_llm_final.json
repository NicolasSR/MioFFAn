        "concepts_list": [
            {
                "name": "Omega",
                "type": "DOMAIN",
                "description": "Main computational domain",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Appears as \u222b_\u03a9 and as the overall region \u03a9 in the formulation."
            },
            {
                "name": "Gamma",
                "type": "DOMAIN",
                "description": "Boundary (interface) set for subdomains",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Used repeatedly as \u0393_i, \u0393_{i,j} to denote interfaces."
            },
            {
                "name": "v",
                "type": "VARIABLE",
                "description": "Test function (gauge function)",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Functions v in V, \u2200 v\u2208V in (3) and as test function in variational form."
            },
            {
                "name": "u",
                "type": "VARIABLE",
                "description": "Unknown field (displacement, temperature)",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Appears as unknown u in the equations of form \u2207v\u00b7\u03ba\u2207u etc."
            },
            {
                "name": "kappa",
                "type": "VARIABLE",
                "description": "Thermal conductivity",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Parameter \u03ba constant in the heat equation."
            },
            {
                "name": "f",
                "type": "VARIABLE",
                "description": "Internal heat source",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Provides forcing f in the weak form."
            },
            {
                "name": "q_bar",
                "type": "VARIABLE",
                "description": "Heat flux",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Boundary condition q\u0304 (\u2264) used in energy balance."
            },
            {
                "name": "V",
                "type": "DOMAIN",
                "description": "Gauge function space of admissible v",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: V is the function space where v is evaluated."
            },
            {
                "name": "Gamma_t",
                "type": "VARIABLE",
                "description": "Interface variable parameterizing interfacial interaction",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: \u0393t denotes time\u2011varying interface \u03b3_i."
            },
            {
                "name": "B",
                "type": "OTHER",
                "description": "Bilinear form operator",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: B(u, v) = \u222b_\u03a9 k \u2207u\u00b7\u2207v d\u03a9."
            },
            {
                "name": "L",
                "type": "OTHER",
                "description": "Linear form",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: L(v) = \u222b_\u03a9 v f d\u03a9 + \u222b_{\u0393t} q\u0304\u00b7v dt."
            },
            {
                "name": "Sigma",
                "type": "OTHER",
                "description": "Stress tensor",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: \u03c3 = C \u03b5 is stress in elastostatics."
            },
            {
                "name": "C",
                "type": "OTHER",
                "description": "Cauchy stress tensor constant",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: Defined as 1/2[\u2207u + (\u2207u)^T]."
            },
            {
                "name": "epsilon",
                "type": "OTHER",
                "description": "Strain tensor",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: \u03b5 = d u."
            },
            {
                "name": "integral_d_Omega",
                "type": "INTEGRATION_VAR",
                "description": "Differential element for domain integration",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: d in \u222b_\u03a9 d\u03a9 denotes the integration variable."
            },
            {
                "name": "integral_d_Gamma",
                "type": "INTEGRATION_VAR",
                "description": "Differential element for interface integration",
                "justification": "NON-EXPLICIT JUSTIFICATIONS: d in \u222b_{\u0393t} d\u0393t denotes the integration variable on the interface."
            }
        ],
