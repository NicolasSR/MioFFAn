        "concepts_list": [
            {
                "name": "displacement_vector",
                "type": "VARIABLE",
                "description": "Spine displacement components in three-dimensional space",
                "justification": "The symbol u is explicitly referred to as the components of the spine displacement in the text, and appears in strain-displacement relations and stress-displacement equations."
            },
            {
                "name": "stress_tensor",
                "type": "VARIABLE",
                "description": "Tensor representing internal forces within the lumbar spine material",
                "justification": "The symbol \u03c3 is described as the components of the stress tensor in the text and appears in the stress equilibrium and stress-displacement relations."
            },
            {
                "name": "strain_tensor",
                "type": "VARIABLE",
                "description": "Tensor representing deformation of the spine material due to applied loads",
                "justification": "The symbol \u03b5 is defined as the components of the strain tensor in the strain-displacement relation (1c)."
            },
            {
                "name": "body_force_vector",
                "type": "VARIABLE",
                "description": "External body forces acting on the lumbar spine",
                "justification": "The symbol f is described as the components of the body force in the text and appears in the stress equilibrium equation."
            },
            {
                "name": "stiffness_tensor",
                "type": "VARIABLE",
                "description": "Material property tensor relating stress to strain in the spine",
                "justification": "The symbol C is described as the components of the stiffness tensor of the spine in the text and appears in the generalized Hooke's law relation (1b)."
            },
            {
                "name": "weight_function",
                "type": "VARIABLE",
                "description": "Test function used in the variational formulation of the finite element method",
                "justification": "The symbol v is referred to as the weight function in the text and is used in the variational statement (Eq. 3)."
            },
            {
                "name": "boundary_force_vector",
                "type": "VARIABLE",
                "description": "External forces applied on the boundary of the lumbar spine domain",
                "justification": "The symbol F is introduced as the body force applied on the boundary and is expressed in terms of the stress tensor via the normal vector."
            },
            {
                "name": "domain_boundary",
                "type": "DOMAIN",
                "description": "The surface of the lumbar spine domain over which boundary integrals are evaluated",
                "justification": "The symbol \u03a9 is used to denote the computational domain and \u2202\u03a9 is used for its boundary, as explicitly stated in the text when discussing boundary conditions and integrals."
            },
            {
                "name": "domain",
                "type": "DOMAIN",
                "description": "The three-dimensional computational domain representing the lumbar spine structure",
                "justification": "The symbol \u03a9 appears multiple times in the context of volume and surface integrals, representing the domain of the spine model."
            },
            {
                "name": "normal_vector",
                "type": "VARIABLE",
                "description": "Outward unit normal vector to the boundary of the domain",
                "justification": "The symbol n is defined as the outward unit normal vector to the domain boundary in the text, and is used in the boundary force expression (Eq. 7)."
            },
            {
                "name": "integration_domain",
                "type": "INTEGRATION_VAR",
                "description": "Volume integral over the domain \u03a9 used in the finite element formulation",
                "justification": "The symbol d\u03a9 appears in volume integrals (e.g., in Eq. 3, 5, 8, 10), representing integration over the domain \u03a9."
            },
            {
                "name": "boundary_integration",
                "type": "INTEGRATION_VAR",
                "description": "Surface integral over the boundary \u2202\u03a9 used in the finite element formulation",
                "justification": "The symbol \u2202\u03a9 appears in surface integrals (e.g., in Eq. 6, 8, 10), representing integration over the boundary of the domain."
            }
        ],
