        "strain_tensor_epsilon_v": {
            "code_var_name": "strain_tensor_epsilon_v",
            "description": "The linearized strain tensor computed from the displacement field, defined as \u03b5(v) = 1/2 (\u2207v + \u2207v^T).\nJUSTIFICATION:\nThe strain tensor \u03b5(v) is explicitly defined as \u03b5(v) = 1/2 (\u2207v + \u2207v^T), and is used in the elastostatics formulation as the input to the stress tensor.",
            "primitive_symbols": [
