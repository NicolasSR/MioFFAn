        },
        "thermal_conductivity_kappa": {
            "code_var_name": "thermal_conductivity_kappa",
            "description": "The thermal conductivity tensor, which governs the heat conduction in the domain and appears in the gradient term of the weak form.\nJUSTIFICATION:\nThe thermal conductivity \u03ba is explicitly mentioned as a given parameter in the thermal boundary value problem and appears in the term \u2207v \u22c5 (\u2207\u03ba u) in the weak form.",
