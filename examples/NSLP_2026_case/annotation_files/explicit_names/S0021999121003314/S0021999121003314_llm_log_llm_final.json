        "concepts_list": [
            {
                "name": "density",
                "type": "VARIABLE",
                "description": "Fluid density in the momentum and mass balance equations.",
                "justification": "where \u03c1 is the fluid density, appearing in the balance of linear momentum and mass equations."
            },
            {
                "name": "viscosity",
                "type": "VARIABLE",
                "description": "Dynamic viscosity of the generalised Newtonian fluid, which may depend on the shear rate.",
                "justification": "\u03bc is the dynamic viscosity, which may further depend on the shear rate and is used in the viscous stress tensor definition."
            },
            {
                "name": "pseudo_traction",
                "type": "VARIABLE",
                "description": "A boundary traction term used to prescribe pressure or enforce mean pressure conditions on the boundary.",
                "justification": "t is defined as a pseudo-traction on the boundary \u0393_N, which may be set to zero or used for prescribing mean pressures."
            },
            {
                "name": "test_velocity",
                "type": "VARIABLE",
                "description": "Test function for the velocity field in the weak formulation, used in the variational equation.",
                "justification": "w_h appears as a test function in the weak form of the momentum equation and is used in the bilinear form with u_h."
            },
            {
                "name": "discrete_velocity",
                "type": "VARIABLE",
                "description": "Discrete approximation of the fluid velocity field in the finite element space.",
                "justification": "u_h is the discrete velocity field, appearing in the weak formulation as the primary unknown and in the test function pair with w_h."
            },
            {
                "name": "discrete_pressure",
                "type": "VARIABLE",
                "description": "Discrete approximation of the fluid pressure field in the finite element space.",
                "justification": "p_h is the discrete pressure field, appearing in the weak formulation as the secondary unknown and in the pressure-pressure bilinear form."
            },
            {
                "name": "boundary_north",
                "type": "DOMAIN",
                "description": "Part of the boundary where Neumann-type boundary conditions are applied, typically for pressure or traction.",
                "justification": "\u0393_N is the part of the boundary where the pseudo-traction t is applied, as defined in the boundary conditions."
            },
            {
                "name": "shear_operator",
                "type": "OPERATOR",
                "description": "The symmetric gradient operator used to compute the shear rate in the stress tensor.",
                "justification": "\u2207_s is the symmetric gradient operator, used in the definition of the shear rate and the viscous stress tensor for generalised Newtonian fluids."
            }
        ],
