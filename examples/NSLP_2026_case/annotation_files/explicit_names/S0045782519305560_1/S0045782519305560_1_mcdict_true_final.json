        "primal_variable_u": {
            "code_var_name": "primal_variable_u",
            "description": "The primary unknown field (e.g., temperature or displacement) that is sought in the weak formulation, with the same symbol used across different physical problems.\nJUSTIFICATION:\nThe variable u is used to denote the temperature in the thermal problem and the displacement in the elastostatics problem. The paper explicitly states that 'the symbol u will be used to denote the primal variable irrespective of the type of problem'.",
            "primitive_symbols": [
                "75"
            ],
